// FILE: juego/jugador.h
#ifndef JUGADOR_H
#define JUGADOR_H

#include <string>

class Jugador {
    std::string nombre;
    int posicion; // 1-based
    int turnos_penalizacion;
    bool en_pozo;
public:
    explicit Jugador(const std::string& nombre_)
        : nombre(nombre_), posicion(1), turnos_penalizacion(0), en_pozo(false) {}
    ~Jugador() = default;

    const std::string& getNombre() const { return nombre; }
    int getPosicion() const { return posicion; }
    void setPosicion(int p) { posicion = p; }

    bool estaEnPozo() const { return en_pozo; }
    void setEnPozo(bool v) { en_pozo = v; }

    int getTurnosPenalizacion() const { return turnos_penalizacion; }
    void addTurnosPenalizacion(int n) { turnos_penalizacion += n; }
    void reducirTurnoPenalizacion() { if (turnos_penalizacion>0) --turnos_penalizacion; }
};

#endif // JUGADOR_H


