void CasillaOca::aplicarEfecto(Jugador* jugador, JuegoOCA* juego) {
    std::cout << jugador->getNombre() << " cae en Oca (" << indice << "). Va a la siguiente Oca y vuelve a tirar.\n";
    int siguiente = juego->buscarSiguienteOca(indice);
    if (siguiente != indice) {
        juego->moverJugadorDirecto(jugador, siguiente);
    }
    // Indica al juego que este jugador debe tener otro turno
    juego->setJugadorTieneTurnoExtra(true);
}


