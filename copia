class Tablero {
    int total;
    std::vector<Casilla*> casillas; // index 1..total, casillas[0] == nullptr
public:
    explicit Tablero(int total_ = 63);
    ~Tablero();

    int numCasillas() const { return total; }
    Casilla* obtenerCasilla(int idx) const;
    void construirCasillasEstandar();
};

#endif // TABLERO_H


// FILE: juego/tablero.cpp
#include "tablero.h"
#include "casillanormal.h"
#include "casillaoca.h"
#include "casillapuente.h"
#include "casillaposada.h"
#include "casillapozo.h"
#include "casillalaberinto.h"
#include "casillacarcel.h"
#include "casillacalavera.h"
#include "casillafinal.h"

#include <iostream>

Tablero::Tablero(int total_) : total(total_) {
    if (total < 10) total = 63; // mínimo sensato
    casillas.resize(total + 1, nullptr);
    construirCasillasEstandar();
}

Tablero::~Tablero() {
    for (size_t i = 1; i < casillas.size(); ++i) {
        delete casillas[i];
        casillas[i] = nullptr;
    }
}

Casilla* Tablero::obtenerCasilla(int idx) const {
    if (idx < 1) idx = 1;
    if (idx > total) idx = total;
    return casillas[idx];
}

void Tablero::construirCasillasEstandar() {
    // Inicializa todas como normales
    for (int i = 1; i <= total; ++i) {
        casillas[i] = new CasillaNormal(i);
    }

    // Puntos especiales según reglas TP (posición por defecto para 63 casillas)
    // Ocas típicas
    std::vector<int> ocas = {9,18,27,36,45,54};
    for (int p : ocas) if (p<=total) {
        delete casillas[p]; casillas[p] = new CasillaOca(p);
    }

    // Puente: 6 -> 12
    if (6<=total) { delete casillas[6]; casillas[6] = new CasillaPuente(6, 12); }

    // Posada: 19
    if (19<=total) { delete casillas[19]; casillas[19] = new CasillaPosada(19); }

    // Pozo: 31
    if (31<=total) { delete casillas[31]; casillas[31] = new CasillaPozo(31); }

    // Laberinto: 42 -> 30
    if (42<=total) { delete casillas[42]; casillas[42] = new CasillaLaberinto(42, 30); }

    // Carcel: 56
    if (56<=total) { delete casillas[56]; casillas[56] = new CasillaCarcel(56); }

    // Calavera: 58 -> 1
    if (58<=total) { delete casillas[58]; casillas[58] = new CasillaCalavera(58); }

    // Final: total
    delete casillas[total]; casillas[total] = new CasillaFinal(total);
}


// FILE: juego/juegooca.h
#ifndef JUEGO_OCA_H
#define JUEGO_OCA_H

#include <vector>
#include <string>

class Jugador;
class Tablero;
class Dado;
class Casilla;

class JuegoOCA {
    std::vector<Jugador*> jugadores;
    Tablero* tablero;
    Dado* dado;
    int indiceJugadorActual;
    bool juegoTerminado;
    Jugador* ganador;

    // Pozo: índice del jugador que actualmente está en el pozo (nullptr si ninguno)
    Jugador* jugadorEnPozo;

    // Bandera para dar turno extra cuando cae en Oca
    bool jugadorTieneTurnoExtra;

public:
    explicit JuegoOCA(int tamaño_tablero = 63);
    ~JuegoOCA();

    void agregarJugador(const std::string& nombre);
    void iniciarPartida();
    void ejecutarTurno();

    void moverJugador(Jugador* jugador, int pasos);
    void moverJugadorDirecto(Jugador* jugador, int posicion); // mueve sin tirar

    int buscarSiguienteOca(int desde) const; // devuelve indice de la siguiente Oca o mismo si no hay

    void declararGanador(Jugador* jugador);
    bool hayGanador() const { return juegoTerminado; }
    Jugador* getGanador() const { return ganador; }

    // Pozo
    void procesarPozo(Jugador* jugador);

    // Turno extra
    void setJugadorTieneTurnoExtra(bool v) { jugadorTieneTurnoExtra = v; }
};

#endif // JUEGO_OCA_H


// FILE: juego/juegooca.cpp
#include "juegooca.h"
#include "jugador.h"
#include "tablero.h"
#include "dado.h"
#include "casilla.h"

#include <iostream>

JuegoOCA::JuegoOCA(int tamaño_tablero)
    : tablero(new Tablero(tamaño_tablero)), dado(new Dado()), indiceJugadorActual(0), juegoTerminado(false), ganador(nullptr), jugadorEnPozo(nullptr), jugadorTieneTurnoExtra(false) {}

JuegoOCA::~JuegoOCA() {
    for (Jugador* j : jugadores) delete j;
    jugadores.clear();
    delete tablero;
    delete dado;
}

void JuegoOCA::agregarJugador(const std::string& nombre) {
    jugadores.push_back(new Jugador(nombre));
}

void JuegoOCA::iniciarPartida() {
    if (jugadores.empty()) {
        std::cerr << "No hay jugadores. Agregar por lo menos uno.\n";
        return;
    }
    indiceJugadorActual = 0;
    juegoTerminado = false;
    ganador = nullptr;
    for (Jugador* j : jugadores) {
        j->setPosicion(1);
    }
}

void JuegoOCA::ejecutarTurno() {
    if (juegoTerminado) return;
    if (jugadores.empty()) return;

    Jugador* j = jugadores[indiceJugadorActual];
    std::cout << "--- Turno de " << j->getNombre() << " (pos " << j->getPosicion() << ")" << " ---\n";

    // Chequear si esta en pozo
    if (j->estaEnPozo()) {
        std::cout << j->getNombre() << " esta en el Pozo. Pierde turno hasta que otro llegue.\n";
        // avanzar turno
        if (!jugadorTieneTurnoExtra) indiceJugadorActual = (indiceJugadorActual + 1) % jugadores.size();
        jugadorTieneTurnoExtra = false;
        return;
    }

    // Chequear penalizaciones por posada / carcel
    if (j->getTurnosPenalizacion() > 0) {
        std::cout << j->getNombre() << " tiene " << j->getTurnosPenalizacion() << " turnos de penalizacion.\n";
        j->reducirTurnoPenalizacion();
        if (!jugadorTieneTurnoExtra) indiceJugadorActual = (indiceJugadorActual + 1) % jugadores.size();
        jugadorTieneTurnoExtra = false;
        return;
    }

    int tiro = dado->tirar();
    std::cout << j->getNombre() << " tira el dado: " << tiro << "\n";
    moverJugador(j, tiro);

    // Si no hay turno extra otorgado por Oca, avanzar al siguiente jugador
    if (!jugadorTieneTurnoExtra) {
        indiceJugadorActual = (indiceJugadorActual + 1) % jugadores.size();
    } else {
        std::cout << j->getNombre() << " obtiene turno extra por caer en Oca.\n";
    }
    // reset flag para el siguiente turno
    jugadorTieneTurnoExtra = false;
}

void JuegoOCA::moverJugador(Jugador* jugador, int pasos) {
    int origen = jugador->getPosicion();
    int destino = origen + pasos;
    int finalPos = tablero->numCasillas();
    if (destino > finalPos) {
        int sobrante = destino - finalPos;
        destino = finalPos - sobrante;
        std::cout << jugador->getNombre() << " se paso del final. Rebota a " << destino << ".\n";
    }
    moverJugadorDirecto(jugador, destino);
}

void JuegoOCA::moverJugadorDirecto(Jugador* jugador, int posicion) {
    jugador->setPosicion(posicion);
    std::cout << jugador->getNombre() << " ahora en " << posicion << ".\n";
    Casilla* cas = tablero->obtenerCasilla(posicion);
    if (cas) {
        cas->aplicarEfecto(jugador, this);
    }
}

int JuegoOCA::buscarSiguienteOca(int desde) const {
    int total = tablero->numCasillas();
    for (int i = desde + 1; i <= total; ++i) {
        Casilla* c = tablero->obtenerCasilla(i);
        if (c && c->nombre() == "Oca") return i;
    }
    // si no hay siguiente, quedarse en la misma
    return desde;
}

void JuegoOCA::declararGanador(Jugador* jugador) {
    juegoTerminado = true;
    ganador = jugador;
}

void JuegoOCA::procesarPozo(Jugador* jugador) {
    if (jugadorEnPozo == nullptr) {
        // nadie en pozo: este jugador queda atrapado
        jugador->setEnPozo(true);
        jugadorEnPozo = jugador;
        std::cout << jugador->getNombre() << " queda atrapado en el Pozo.\n";
    } else if (jugadorEnPozo == jugador) {
        // ya estaba en el pozo, nada nuevo
    } else {
        // otro jugador cae en el pozo: libera al anterior y el nuevo queda atrapado
        std::cout << jugador->getNombre() << " llega al Pozo. Libera a " << jugadorEnPozo->getNombre() << " y queda atrapado.\n";
        jugadorEnPozo->setEnPozo(false);
        jugador->setEnPozo(true);
        jugadorEnPozo = jugador;
    }
}


// FILE: main.cpp
#include <iostream>
#include "juego/juegooca.h"

int main() {
    JuegoOCA juego(63);
    juego.agregarJugador("Alice");
    juego.agregarJugador("Bob");
    juego.agregarJugador("Carol");

    juego.iniciarPartida();

    // Simular hasta que haya un ganador o se alcance un numero maximo de turnos
    int max_turnos = 1000;
    int contador = 0;
    while (!juego.hayGanador() && contador < max_turnos) {
        juego.ejecutarTurno();
        ++contador;
    }

    if (juego.hayGanador()) {
        std::cout << "Ganador: " << juego.getGanador()->getNombre() << " en " << contador << " turnos.\n";
    } else {
        std::cout << "No hubo ganador en " << max_turnos << " turnos.\n";
    }

    return 0;
}
